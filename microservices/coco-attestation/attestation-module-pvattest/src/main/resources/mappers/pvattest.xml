<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="PvattestModule">

    <select id="retrieveConfigData" parameterType="Long" resultType="com.suse.coco.model.AttestationConfigData">
        SELECT cfg.server_id, cfg.in_data
        FROM suseServerCocoAttestationReport rpt
        JOIN suseServerCocoAttestationConfig cfg ON rpt.server_id = cfg.server_id
        WHERE rpt.id = #{reportId}
    </select>
</mapper>
